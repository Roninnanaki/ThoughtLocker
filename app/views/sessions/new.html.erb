<% provide(:title, "Sign in") %>
<div class="text-center">
  <h1>Welcome to ThoughtLocker</h1>
  <h2>Sign in</h2>
</div>
<div class="row justify-content-center">
  <div class="col-md-6">
    <%= form_for(:session, url: sessions_path) do |f| %>
      <div class="mb-3">
        <%= f.text_field :email, id: "login_email_form", placeholder: "Email", class: "form-control" %>
      </div>
      <div class="mb-3">
        <%= f.password_field :password, id: "login_password_form", placeholder: "Password", class: "form-control" %>
      </div>
      <%= f.submit "Login", class: "btn btn-lg btn-primary" %>
    <% end %>
    <p class="mt-3">New user? <%= link_to "Sign up now!", signup_path %></p>
  </div>
</div>
