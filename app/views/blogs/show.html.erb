<% provide(:title, @blog.name) %>
<div class="col-md-8">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2><%= @blog.name %></h2>
    <% if current_user_made_this_blog?(@blog) %>
      <%= link_to "Edit", edit_blog_path(@blog), class: "btn btn-lg btn-primary" %>
    <% end %>
  </div>

  <% if @blog.posts.any? %>
    <% @blog.posts.recent.each do |post| %>
      <div class="card mb-3">
        <div class="card-body">
          <h3 class="card-title"><%= post.title %></h3>
          <% if post.photo.attached? %>
            <div class="mb-3">
              <%= image_tag post.photo.variant(resize_to_limit: [500, 500]), class: "img-fluid" %>
            </div>
          <% end %>
          <p class="card-text"><%= post.content %></p>
          <p class="text-muted"><%= post.source %></p>
          <small class="text-muted">Posted <%= time_ago_in_words(post.created_at) %> ago.</small>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
