        <ul class="navbar-nav">
          <li class="nav-item"><%= link_to "Profile", current_user, class: "nav-link" %></li>
          <li class="nav-item"><%= link_to "Sign out", signout_path, data: { turbo_method: :delete }, class: "nav-link" %></li>
        </ul>
      <% end %>
    </div>
  </div>
</nav>
<div style="margin-top: 70px;"></div>
